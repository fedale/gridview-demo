#!/usr/bin/env bash
# Copy the gridview bundle's Stimulus controllers + JS helpers into the app asset
# root (assets/vendor-gridview/). They must live under assets/ — not be referenced
# from the symlinked vendor path — so they can be imported *relatively* in
# assets/bootstrap.js; only then does AssetMapper follow each controller's own
# `../i18n.js` style imports and add them to the import map.
#
# Re-run after updating fedale/gridview-bundle. The date-filter controller is
# skipped on purpose (it pulls flatpickr, which is deferred —
# see docs/flatpickr-assetmapper-plan.md).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SRC="$ROOT/vendor/fedale/gridview-bundle/assets"
DEST="$ROOT/assets/vendor-gridview"

rm -rf "$DEST"
mkdir -p "$DEST/controllers"

cp -L "$SRC/i18n.js"          "$DEST/i18n.js"
cp -L "$SRC/preferences.js"   "$DEST/preferences.js"
cp -L "$SRC/prompt-modal.js"  "$DEST/prompt-modal.js"

for f in "$SRC"/controllers/*_controller.js; do
    name="$(basename "$f")"
    [ "$name" = "gridview-date-filter_controller.js" ] && continue
    cp -L "$f" "$DEST/controllers/$name"
done

echo "Synced gridview assets into $DEST ($(ls "$DEST/controllers" | wc -l) controllers)."

# Copy the EasyAdmin "shell" theme CSS so the gridview pages can reuse the same
# outer layout (.wrapper / .sidebar-wrapper / .main-content) as EasyAdmin. Only
# the shell files are copied — the component files (buttons/forms/datagrids/...)
# are left out on purpose so they don't clash with the grid's Bootstrap + .gv-*
# styles. They are imported from assets/gridview-page.js.
EA_SRC="$ROOT/vendor/easycorp/easyadmin-bundle/assets/css/easyadmin-theme"
EA_DEST="$ROOT/assets/vendor-easyadmin"

rm -rf "$EA_DEST"
mkdir -p "$EA_DEST"
for name in color-palette.css variables-theme.css base.css menu.css; do
    cp -L "$EA_SRC/$name" "$EA_DEST/$name"
done

echo "Synced EasyAdmin shell CSS into $EA_DEST ($(ls "$EA_DEST" | wc -l) files)."
