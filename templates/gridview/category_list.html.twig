{# Custom ListView item for the Category grid, wired via CategoryController:
   options.list.template. A clean full-width list row (no table-like dividers, no
   decorative colour): name + ID badge and subtitle, the description, then a meta
   line with position / posts / published; the action buttons stay on the right.

   Context: gridview, row, rowIndex, columns (+ models, pagination, form). #}
{% set liAttr = gridview.regionAttr('row')|merge(row.attr ?? {}) %}
{% set liAttr = liAttr|merge({'class': ('gv-list-item category-li ' ~ liAttr.class|default(''))|trim}) %}
{% set editUrl = path('gridview_category_update', {id: row.data.id}) %}
{% set accent = row.data.color|default('#6b7280') %}
<li {{ liAttr|options }} style="--card-accent: {{ accent }};">
    <div class="category-li__main">
        <div class="category-li__head">
            <span class="category-li__title">{{ row.data.name }}</span>
            <span class="category-li__id">ID {{ row.data.id }}</span>
        </div>
        <span class="category-li__subtitle">Categoria</span>

        {% if row.data.description %}
            <p class="category-li__desc">{{ row.data.description|striptags }}</p>
        {% endif %}

        <div class="category-li__meta">
            <span>Posizione <strong>#{{ row.data.position }}</strong></span>
            <span><strong>{{ row.data.postCount }}</strong> articoli</span>
            <span class="category-li__published">{{ row.data.publishedCount }} pubblicati</span>
        </div>
    </div>

    <div class="category-li__actions">
        <a class="category-li__btn" href="{{ editUrl }}"
           data-action="gridview-crud#open" data-gridview-crud-url-param="{{ editUrl }}">Modifica</a>
        <a class="category-li__btn category-li__btn--primary"
           href="{{ path('admin_post_index', {_locale: app.request.locale, filters: {category: {value: row.data.id, comparison: '='}}}) }}">Vedi articoli</a>
    </div>
</li>
