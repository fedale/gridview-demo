{#
   Gridview list page. Wrapped in the EasyAdmin-style shell (gridview/layout) so
   it shares the sidebar + main-content chrome. The page title comes from the
   active sidebar item (see layout); the grid widget renders in the content body.
#}
{% extends 'gridview/layout.html.twig' %}

{% block grid %}
    {% include '@FedaleGridview/gridview/_grid.html.twig' with {
        'gridview': gridview,
        'columns': columns,
        'models': models,
        'pagination': pagination,
        'form': form is defined ? form : null
    } %}
{% endblock %}
