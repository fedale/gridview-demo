{#
   Gridview demo landing page. Reuses the shell (gridview/layout) for the sidebar
   + chrome, but has no grid: it drops the content-top search box and renders a
   welcome message in the content body.
#}
{% extends 'gridview/layout.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block content_title %}Dashboard{% endblock %}

{# No grid here, so the top-bar search would do nothing: hide it. #}
{% block content_search %}{% endblock %}

{% block grid %}
    <div class="gv-dashboard-welcome">
        <h2>Welcome to the Fedale Gridview Demo project!</h2>
        <p>This is a demo project to show you how the Fedale Gridview bundle works.
           Use the sidebar links to navigate through the demo application.</p>
    </div>
{% endblock %}
